# Configuration SMTP pour l'envoi d'emails
# Copiez ce fichier vers .env et remplissez avec vos vraies valeurs

# Serveur SMTP (Gmail, OVH, etc.)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Identifiants SMTP
# Pour Gmail : créez un "mot de passe d'application" dans les paramètres de sécurité
# https://support.google.com/accounts/answer/185833
SMTP_USERNAME=votre-email@gmail.com
SMTP_PASSWORD=votre-mot-de-passe-application

# Email d'envoi
FROM_EMAIL=contact@bainsopera.com

# Exemple pour OVH :
# SMTP_SERVER=ssl0.ovh.net
# SMTP_PORT=587
# SMTP_USERNAME=contact@bainsopera.com
# SMTP_PASSWORD=votre-mot-de-passe
# FROM_EMAIL=contact@bainsopera.com
